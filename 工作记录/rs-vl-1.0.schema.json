{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/schemas/rs-vl-1.0.schema.json",
  "title": "RS-VL Canonical Manifest Record",
  "description": "Model-neutral, lossless metadata record for remote-sensing vision-language datasets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "image_group_id",
    "source",
    "source_split",
    "task",
    "language",
    "media",
    "prompt",
    "target",
    "provenance",
    "status"
  ],
  "properties": {
    "schema_version": {"const": "rs-vl-1.0"},
    "id": {"type": "string", "minLength": 1},
    "image_group_id": {
      "type": "string",
      "minLength": 1,
      "description": "Leakage-control unit. Records sharing the same underlying scene/image group must share this id."
    },
    "source": {
      "enum": [
        "levir_mci",
        "vrsbench",
        "xlrs_lite",
        "xlrs_caption_zh",
        "xlrs_grounding_zh",
        "mme_realworld_rs"
      ]
    },
    "source_split": {"enum": ["train", "val", "test", "benchmark", "unknown"]},
    "task": {
      "enum": [
        "change_captioning",
        "change_detection",
        "image_captioning",
        "visual_grounding",
        "vqa"
      ]
    },
    "language": {"enum": ["en", "zh", "mixed", "unknown"]},
    "media": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/mediaItem"}
    },
    "prompt": {"type": "string", "minLength": 1},
    "choices": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 2,
      "uniqueItems": true
    },
    "target": {"$ref": "#/$defs/target"},
    "sensor": {"enum": ["optical", "sar", "multispectral", "unknown"]},
    "bands": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "gsd_m": {
      "type": ["number", "null"],
      "exclusiveMinimum": 0,
      "description": "Ground sample distance in metres/pixel. Null when not supplied by the source. Never infer it from image width."
    },
    "category": {"type": ["string", "null"]},
    "provenance": {"$ref": "#/$defs/provenance"},
    "status": {"enum": ["valid", "invalid"]},
    "errors": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "meta": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "fileLocator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": {"const": "file"},
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?![A-Za-z]:[\\\\/])(?![\\\\/]).+",
          "description": "POSIX-style path relative to the configured dataset root."
        }
      }
    },
    "arrowLocator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path", "row", "column"],
      "properties": {
        "type": {"const": "arrow"},
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?![A-Za-z]:[\\\\/])(?![\\\\/]).+"
        },
        "row": {"type": "integer", "minimum": 0},
        "column": {"type": "string", "minLength": 1},
        "index": {"type": "integer", "minimum": 0}
      }
    },
    "mediaItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["media_id", "role", "locator", "width", "height", "channels"],
      "properties": {
        "media_id": {"type": "string", "minLength": 1},
        "role": {"enum": ["image", "t1", "t2", "frame", "unknown"]},
        "locator": {
          "oneOf": [
            {"$ref": "#/$defs/fileLocator"},
            {"$ref": "#/$defs/arrowLocator"}
          ]
        },
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "channels": {"type": "integer", "minimum": 1},
        "format": {"type": ["string", "null"]},
        "byte_size": {"type": ["integer", "null"], "minimum": 0},
        "sha256_encoded": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$",
          "description": "SHA-256 of the original encoded media bytes, without decoding or re-encoding."
        }
      }
    },
    "box": {
      "type": "object",
      "additionalProperties": false,
      "required": ["xyxy", "coordinate_space"],
      "properties": {
        "xyxy": {
          "type": "array",
          "prefixItems": [
            {"type": "number", "minimum": 0, "maximum": 1},
            {"type": "number", "minimum": 0, "maximum": 1},
            {"type": "number", "minimum": 0, "maximum": 1},
            {"type": "number", "minimum": 0, "maximum": 1}
          ],
          "items": false
        },
        "coordinate_space": {"const": "normalized_original_xyxy"},
        "label": {"type": ["string", "null"]}
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "texts": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1
        },
        "answer": {"type": "string", "minLength": 1},
        "class_label": {"type": "string", "minLength": 1},
        "boxes": {
          "type": "array",
          "items": {"$ref": "#/$defs/box"},
          "minItems": 1
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["annotation_path", "record_id", "license_id"],
      "properties": {
        "annotation_path": {"type": "string", "minLength": 1},
        "record_id": {"type": ["string", "integer"]},
        "license_id": {"type": "string", "minLength": 1},
        "notes": {"type": ["string", "null"]}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"task": {"enum": ["change_captioning", "image_captioning"]}, "status": {"const": "valid"}}, "required": ["task", "status"]},
      "then": {"properties": {"target": {"required": ["texts"]}}}
    },
    {
      "if": {"properties": {"task": {"const": "change_detection"}, "status": {"const": "valid"}}, "required": ["task", "status"]},
      "then": {"properties": {"target": {"required": ["class_label"]}}}
    },
    {
      "if": {"properties": {"task": {"const": "visual_grounding"}, "status": {"const": "valid"}}, "required": ["task", "status"]},
      "then": {"properties": {"target": {"required": ["boxes"]}}}
    },
    {
      "if": {"properties": {"task": {"const": "vqa"}, "status": {"const": "valid"}}, "required": ["task", "status"]},
      "then": {"properties": {"target": {"required": ["answer"]}}}
    },
    {
      "if": {"properties": {"task": {"enum": ["change_captioning", "change_detection"]}}},
      "then": {
        "properties": {
          "media": {
            "minItems": 2,
            "maxItems": 2,
            "allOf": [
              {
                "contains": {"properties": {"role": {"const": "t1"}}, "required": ["role"]},
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {"properties": {"role": {"const": "t2"}}, "required": ["role"]},
                "minContains": 1,
                "maxContains": 1
              }
            ]
          }
        }
      }
    }
  ]
}
